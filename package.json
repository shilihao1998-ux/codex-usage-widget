{
  "name": "codex-usage-widget",
  "version": "1.1.0",
  "private": true,
  "description": "Desktop widget showing your OpenAI Codex quota (5-hour and weekly windows), read from the same local app-server API the official Codex app uses.",
  "keywords": [
    "codex",
    "openai",
    "quota",
    "rate-limit",
    "usage",
    "desktop-widget",
    "electron",
    "tray"
  ],
  "license": "MIT",
  "author": "Shilihao (https://github.com/shilihao1998-ux)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shilihao1998-ux/codex-usage-widget.git"
  },
  "homepage": "https://github.com/shilihao1998-ux/codex-usage-widget#readme",
  "bugs": "https://github.com/shilihao1998-ux/codex-usage-widget/issues",
  "main": "src/ui/main.js",
  "bin": {
    "codex-usage": "bin/codex-usage.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "electron .",
    "test": "node test/plugin-host.test.js && node test/burn.test.js",
    "usage": "node bin/codex-usage.js once",
    "verify": "node bin/codex-usage.js verify",
    "serve": "node bin/codex-usage.js serve",
    "backgrounds": "node tools/make-backgrounds.js",
    "icon": "node tools/make-icon.js",
    "dist": "npm run icon && electron-builder --win --publish never"
  },
  "devDependencies": {
    "electron": "^37.10.3",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.shilihao.codex-usage-widget",
    "productName": "Codex Usage Widget",
    "copyright": "Copyright (c) 2026 Shilihao",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "bin/**/*",
      "plugins/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/backgrounds",
        "to": "backgrounds"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Codex Usage Widget",
      "artifactName": "Codex-Usage-Widget-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "Codex-Usage-Widget-${version}-portable.${ext}"
    }
  }
}
